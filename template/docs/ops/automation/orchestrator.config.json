{
  "executor": {
    "command": "codex -a never exec --json --sandbox {sandbox_mode} -c model_reasoning_effort={reasoning_effort} -m {model} {prompt}",
    "promptTemplate": "@canonical-executor-prompt",
    "timeoutSeconds": 3600,
    "maxSessionsPerPlan": 12,
    "contextBudget": {
      "minRemaining": 12000,
      "minRemainingPercent": 0.15
    },
    "roles": {
      "worker": {
        "model": "gpt-5.4",
        "reasoningEffort": "high",
        "sandboxMode": "full-access",
        "instructions": "Implement the next concrete slice, keep plan status accurate, and move the plan to validation only when every must-land item is checked."
      },
      "reviewer": {
        "model": "gpt-5.4",
        "reasoningEffort": "high",
        "sandboxMode": "read-only",
        "instructions": "Review for correctness, regressions, test gaps, and scope omissions. Hand work back to the worker if fixes are still required."
      }
    }
  },
  "runtime": {
    "contextPath": "docs/generated/AGENT-RUNTIME-CONTEXT.md",
    "checkpointDir": "docs/ops/automation/runtime/state",
    "handoffDir": "docs/ops/automation/handoffs"
  },
  "logging": {
    "output": "pretty",
    "failureTailLines": 60,
    "heartbeatSeconds": 12,
    "stallWarnSeconds": 120
  },
  "git": {
    "atomicCommits": true
  },
  "risk": {
    "defaultMaxRisk": "high",
    "reviewRequired": [
      "medium",
      "high"
    ],
    "securityApprovalRequired": [
      "high"
    ]
  },
  "validation": {
    "always": [
      {
        "id": "repo:verify-fast",
        "command": "npm run verify:fast",
        "type": "always"
      }
    ],
    "hostRequired": [
      {
        "id": "repo:verify-full",
        "command": "npm run verify:full",
        "type": "host-required"
      }
    ]
  }
}
